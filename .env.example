# ─────────────────────────────────────────────────────────────────────────────
# DokMaker environment variables
# Copy to `.env.local` (dev) or set in your Vercel project (prod).
# Secrets marked SERVER-ONLY must NEVER be prefixed with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Prisma) ────────────────────────────────────────────────────────
# Required at runtime and for `prisma migrate`. `prisma generate` works without
# these (see prisma.config.ts), but `migrate`/`db push`/`deploy` need real values.
DATABASE_URL="postgresql://USER:PASS@HOST:5432/dokmaker?schema=public"
DIRECT_URL="postgresql://USER:PASS@HOST:5432/dokmaker?schema=public"

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"

# ── Supabase Auth (public — safe to expose to the browser) ───────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"
# SERVER-ONLY secret used for privileged operations (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=""

# ── Pakasir (payment gateway) — SERVER-ONLY SECRETS ──────────────────────────
# Never prefix with NEXT_PUBLIC_. Never log these values.
PAKASIR_PROJECT_SLUG="your-pakasir-project-slug"
PAKASIR_BASE_URL="https://app.pakasir.com"
PAKASIR_API_KEY="YOUR-SECRET-PAKASIR-API-KEY"
PAKASIR_WEBHOOK_URL=""
# Sandbox mode is derived from SERVER config ONLY (never from the webhook body),
# so a forged request cannot skip upstream verification. Set to "true" for
# sandbox/staging where the webhook body status is authoritative. In PRODUCTION
# leave this UNSET/false so every webhook is confirmed via the Pakasir
# Transaction Detail API before crediting a wallet.
PAKASIR_SANDBOX="false"
# Optional HMAC shared secret for webhook signature verification (defense in depth).
# Strongly recommended in production. Leave blank to rely solely on the Pakasir
# Transaction Detail API confirmation.
PAKASIR_WEBHOOK_SECRET=""

# ── Cloudflare R2 storage for final PDF artifacts — SERVER-ONLY SECRETS ───────
# Final PDFs are served via signed temporary URLs; these never appear in the browser bundle.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── Upstash Redis (distributed rate limiting) ────────────────────────────────
# Optional in dev (falls back to in-memory). Required in production for
# effective rate limiting across serverless instances.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Pollinations.ai provider for AI Reference Invoice Generator ──────────────
# POLLINATIONS_API_KEY is a SERVER-ONLY secret. Never prefix with NEXT_PUBLIC_,
# never log its value, never ship it to the browser bundle.
POLLINATIONS_API_KEY=""
POLLINATIONS_BASE_URL="https://gen.pollinations.ai"
AI_INVOICE_ANALYSIS_MODEL="qwen-vision"
AI_INVOICE_IMAGE_MODEL="gptimage-large"
AI_INVOICE_GENERATION_PRICE_IDR="10000"
